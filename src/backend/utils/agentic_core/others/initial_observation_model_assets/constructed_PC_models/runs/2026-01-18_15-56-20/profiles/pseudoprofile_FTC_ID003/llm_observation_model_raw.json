        "13:30-14:30",
        "15:30-16:30",
        "18:00-19:00",
        "20:00-21:00"
      ],
      "recall_window": "since_last_prompt",
      "expected_total_prompts": 84,
      "notes": "Six brief EMA prompts per day across wake hours with mild jitter to reduce anticipation."
    },
    "daily_diary": {
      "enabled": true,
      "entries_per_day": 1,
      "anchor_times_local": [
        "07:30"
      ],
      "expected_total_entries": 14,
      "notes": "One-line daily-context diary to anchor intra-day variability."
    },
    "passive_streams": {
      "enabled": false,
      "aggregation_strategy": "per_prompt_aggregation",
      "notes": "Optional passive sensors (HRV proxies, movement) can be added if feasible."
    },
    "minimum_total_observations_target": 120,
    "gvar_readiness_notes": "Feasible with six parsimonious predictors and eight criteria; cross-domain synergy supports robust gVAR estimation.",
    "variance_support_notes": "Expect substantial within-person variability across days; plan to apply per-subject z-scoring or similar normalization.",
    "missingness_risk_notes": "Prompts may be missed; implement reminders and diary fallback; consider multiple imputation later if needed."
  },
