    {
      "SurveyID": "SV_3A8A86302932918",
      "Element": "SQ",
      "PrimaryAttribute": "QID34",
      "SecondaryAttribute": "Afronding en terugbezorgingDank u voor het invullen van alle zes delen voor uw toegewezen casus en de afsluitende reflec",
      "TertiaryAttribute": null,
      "Payload": {
        "Type": "DB",
        "Selector": "TB",
        "SubSelector": "TX",
        "DataExportTag": "AFRONDING",
        "QuestionText": "<h2 style=\"color:#1E3A5F;border-bottom:2px solid #1D4ED8;padding-bottom:6px;margin-top:0;\">Afronding en terugbezorging</h2><p style=\"margin:5px 0;\">Dank u voor het invullen van alle zes delen voor uw toegewezen casus en de afsluitende reflectievragen.</p><div style=\"background:#F8FAFC;border:1.5px solid #CBD5E1;border-radius:6px;padding:14px 18px;margin:10px 0;\"><div style=\"font-weight:bold;color:#475569;margin-bottom:8px;font-size:13px;\">Checklist voor terugbezorging</div><div style=\"font-size:13px;line-height:1.65;color:#1E293B;\"><ul style=\"margin:4px 0;padding-left:22px;\"><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 1 symptoomlabels ingevuld.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 2 behandelingsoptielabels ingevuld.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 3 alle 5 behandelingsopties gerangschikt.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 4 exact 6 EMA-items geselecteerd.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 5 een mobiele coachingsboodschap geschreven.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 6 de drie reflectievragen beantwoord.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Mijn antwoorden weerspiegelen mijn eigen klinische oordeelsvorming zonder gebruik van generatieve AI of andere externe hulp.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik begrijp dat mijn antwoorden geanonimiseerd worden voor analyse.</li></ul></div></div><div style=\"background:#EFF6FF;border:2px solid #1D4ED8;border-radius:6px;padding:14px 18px;margin:10px 0;\"><div style=\"font-weight:bold;color:#1D4ED8;margin-bottom:8px;font-size:13px;\">Uw antwoorden zijn opgeslagen</div><div style=\"font-size:13px;line-height:1.65;color:#1E293B;\"><p style=\"margin:5px 0;\">Na het indienen van deze survey worden uw antwoorden automatisch opgeslagen in het systeem. U hoeft niets terug te mailen.</p><p style=\"margin:5px 0;\">Na ontvangst worden uw antwoorden geanonimiseerd en opgenomen in het expertreferentiecorpus voor de latere blinde evaluatie van PHOENIX.</p><p style=\"margin:5px 0;\"><strong>Hartelijk dank voor uw waardevolle bijdrage aan dit onderzoek.</strong></p><p style=\"margin:5px 0;\">Vragen of opmerkingen? Neem contact op via: <strong>stijn.vanseveren@ugent.be</strong></p></div></div>",
        "QuestionDescription": "Afronding en terugbezorgingDank u voor het invullen van alle zes delen voor uw toegewezen casus en de afsluitende reflec",
        "ChoiceOrder": [],
        "Choices": {},
        "GradingData": [],
        "Language": [],
        "NextChoiceId": 1,
        "NextAnswerId": 1,
        "QuestionText_Unsafe": "<h2 style=\"color:#1E3A5F;border-bottom:2px solid #1D4ED8;padding-bottom:6px;margin-top:0;\">Afronding en terugbezorging</h2><p style=\"margin:5px 0;\">Dank u voor het invullen van alle zes delen voor uw toegewezen casus en de afsluitende reflectievragen.</p><div style=\"background:#F8FAFC;border:1.5px solid #CBD5E1;border-radius:6px;padding:14px 18px;margin:10px 0;\"><div style=\"font-weight:bold;color:#475569;margin-bottom:8px;font-size:13px;\">Checklist voor terugbezorging</div><div style=\"font-size:13px;line-height:1.65;color:#1E293B;\"><ul style=\"margin:4px 0;padding-left:22px;\"><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 1 symptoomlabels ingevuld.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 2 behandelingsoptielabels ingevuld.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 3 alle 5 behandelingsopties gerangschikt.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 4 exact 6 EMA-items geselecteerd.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 5 een mobiele coachingsboodschap geschreven.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik heb in Deel 6 de drie reflectievragen beantwoord.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Mijn antwoorden weerspiegelen mijn eigen klinische oordeelsvorming zonder gebruik van generatieve AI of andere externe hulp.</li><li style=\"margin:3px 0;\">&#9744;&nbsp; Ik begrijp dat mijn antwoorden geanonimiseerd worden voor analyse.</li></ul></div></div><div style=\"background:#EFF6FF;border:2px solid #1D4ED8;border-radius:6px;padding:14px 18px;margin:10px 0;\"><div style=\"font-weight:bold;color:#1D4ED8;margin-bottom:8px;font-size:13px;\">Uw antwoorden zijn opgeslagen</div><div style=\"font-size:13px;line-height:1.65;color:#1E293B;\"><p style=\"margin:5px 0;\">Na het indienen van deze survey worden uw antwoorden automatisch opgeslagen in het systeem. U hoeft niets terug te mailen.</p><p style=\"margin:5px 0;\">Na ontvangst worden uw antwoorden geanonimiseerd en opgenomen in het expertreferentiecorpus voor de latere blinde evaluatie van PHOENIX.</p><p style=\"margin:5px 0;\"><strong>Hartelijk dank voor uw waardevolle bijdrage aan dit onderzoek.</strong></p><p style=\"margin:5px 0;\">Vragen of opmerkingen? Neem contact op via: <strong>stijn.vanseveren@ugent.be</strong></p></div></div>",
