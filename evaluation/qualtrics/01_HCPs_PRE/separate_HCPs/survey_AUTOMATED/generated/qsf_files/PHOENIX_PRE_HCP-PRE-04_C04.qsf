      "SecondaryAttribute": "Voorbeeld &#8212; Deel 2: Initieel observatiemodelHoe genereert u behandelingsoptielabels?Gestandaardiseerde symptomen u",
      "TertiaryAttribute": null,
      "Payload": {
        "Type": "DB",
